# ──────────────────────────────────────────────────────────────
# DN Notification — environment variables
# Copy to .env and fill in real values. The .env file is loaded
# by docker compose (env_file: .env) and by the app via pydantic.
# ──────────────────────────────────────────────────────────────

# ── Telegram API credentials (https://my.telegram.org/apps) ──
TG_API_ID=123456
TG_API_HASH=your_api_hash_here
TG_PHONE=+1234567890
TG_SESSION_NAME=telegram_session

# ── Server ────────────────────────────────────────────────────
# HOST/PORT are read by the FastAPI app (for direct runs).
# HOST_PORT controls the host-side port mapping in docker-compose.
HOST=0.0.0.0
PORT=8000
HOST_PORT=8000
LOG_LEVEL=INFO

# ── Security ──────────────────────────────────────────────────
# Random string. The API rejects requests without a matching
# X-API-KEY header. Rotate periodically.
API_KEY=your_secret_api_key_here

# ── Search ────────────────────────────────────────────────────
SEARCH_LIMIT_PER_CHAT=200
SEARCH_TOP_MATCHES=3
SEARCH_CACHE_TTL=300

# ── Persistent storage (in-container) ────────────────────────
# All paths below are inside the container. The host bind-mount
# in docker-compose.yaml maps /var/lib/dn-notification on the
# host onto /var/lib/dn-notification inside the container, so
# everything written here is persistent.
#
# Voices are loaded from DATA_DIR/voices (e.g. limited.ogg, expired.ogg).
# The session file is stored under DATA_DIR/session and the
# application logs under DATA_DIR/logs.
DATA_DIR=/var/lib/dn-notification
VOICES_DIR=/var/lib/dn-notification/voices
SESSION_DIR=/var/lib/dn-notification/session
LOGS_DIR=/var/lib/dn-notification/logs

# ── Docker image ─────────────────────────────────────────────
# Pre-built image pulled by docker compose. Override to pin a
# specific tag or to use your own registry.
DOCKER_IMAGE=docker.io/erfan/dn-notification:latest
