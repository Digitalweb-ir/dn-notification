# ──────────────────────────────────────────────────────────────
# DN Notification — environment variables
# Copy to .env and fill in real values. The .env file is loaded
# by docker compose (env_file: .env) and by the app via pydantic.
# ──────────────────────────────────────────────────────────────

# ── Telegram API credentials (https://my.telegram.org/apps) ──
TG_API_ID=123456
TG_API_HASH=your_api_hash_here
TG_PHONE=+1234567890
TG_SESSION_NAME=telegram_session

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
HOST_PORT=8000
DEBUG=false
# UVICORN_LOG_LEVEL is derived from DEBUG automatically by
# docker-entrypoint.sh (true→debug, false→info).  Only set this
# manually if you need to override the automatic mapping.
# UVICORN_LOG_LEVEL=debug

# ── Security ──────────────────────────────────────────────────
# Random string. The API rejects requests without a matching
# X-API-KEY header. Rotate periodically.
API_KEY=your_secret_api_key_here

# ── Search ────────────────────────────────────────────────────
SEARCH_TOP_MATCHES=3
SEARCH_CACHE_TTL=300

# ── Persistent storage (in-container) ────────────────────────
# All persistent data lives under this single directory inside
# the container. The host bind-mount in docker-compose.yaml maps
# /var/lib/dn-notification on the host onto the same path inside
# the container. Voices, session, and logs are derived from
# DATA_DIR automatically by the app (no need to set them here).
DATA_DIR=/var/lib/dn-notification

