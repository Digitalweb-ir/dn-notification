#!/usr/bin/env bash
# =============================================================================
# .githooks/pre-push — defense-in-depth version check
# =============================================================================
# Defense-in-depth for the commit-msg hook. If a developer bypassed the
# commit-msg hook (e.g. via `git commit --no-verify`, a GUI client, or
# because they cloned the repo without running the bootstrap), the local
# VERSION file may not match the work being pushed. CI's --check job will
# catch this — but only after the push lands, leaving a broken main branch
# for a few minutes and forcing a follow-up fix commit.
#
# This hook runs `./version_bump.sh --check` BEFORE the push is allowed to
# proceed. If VERSION is out of sync with the commits about to be pushed,
# the push is aborted with a clear error pointing the developer at the
# local bump command they should run.
#
# Wired up via the same `core.hooksPath` setting as commit-msg. If the
# developer hasn't run the bootstrap, this hook won't fire either — and
# that's exactly what the bootstrap is for (see Makefile target
# `install-hooks`).
# =============================================================================
set -Eeuo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT="$REPO_ROOT/version_bump.sh"

if [[ ! -x "$SCRIPT" ]]; then
    # Make it executable and retry. Common in fresh clones where the +x
    # bit didn't survive the zip/tarball.
    if [[ -f "$SCRIPT" ]]; then
        chmod +x "$SCRIPT"
    else
        echo "pre-push: $SCRIPT not found at repo root" >&2
        exit 1
    fi
fi

# --check exits 0 if VERSION matches the implied bump from commits since
# the last tag, 1 otherwise. We don't want the hook to be silent about
# either path; let the script's own messaging reach the user.
"$SCRIPT" --check
ec=$?

if [[ $ec -ne 0 ]]; then
    cat >&2 <<'EOF'

pre-push: refusing to push — VERSION is out of sync with the commits
about to be pushed. This usually means a recent commit was made without
the auto-bump hook firing (e.g. `git commit --no-verify` or a GUI client).

Fix it locally by running:

  ./version_bump.sh        # apply the implied bump
  git add VERSION app/__init__.py
  git commit --amend --no-edit   # or a fresh "chore: ..." commit
  git push

Then retry the push. If you genuinely want to push without bumping
(skip this safety net for a one-off), use `git push --no-verify`.
EOF
    exit 1
fi

exit 0
