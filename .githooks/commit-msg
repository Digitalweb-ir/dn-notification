#!/usr/bin/env bash
# =============================================================================
# .githooks/commit-msg — auto-bump VERSION on Conventional Commits
# =============================================================================
# Wired up via `git config core.hooksPath .githooks`. Reads the in-flight
# commit message from $1, parses it for a Conventional Commits prefix
# (break / feat / fix, case- and whitespace-tolerant), and if a bump is
# warranted, updates VERSION and app/__init__.py and stages them so the
# bump lands in the SAME commit as the change that caused it.
#
# Rationale: this keeps the version bump atomic with the change. A `fix:`
# commit lands with VERSION already bumped to the patch-release version,
# so `git log` and `git tag` always agree with VERSION, and CI's `--check`
# mode is idempotent.
#
# To skip the auto-bump for a one-off commit (e.g. a tooling change that
# shouldn't affect the version), set `SKIP_VERSION_BUMP=1` in the
# environment, or use a commit subject that doesn't start with one of
# the recognised prefixes.
# =============================================================================
set -Eeuo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
MSG_FILE="${1:-}"

if [[ -z "$MSG_FILE" || ! -f "$MSG_FILE" ]]; then
    echo "commit-msg: missing or unreadable message file: '$MSG_FILE'" >&2
    exit 1
fi

# The message file may contain a commit-message-with-comments preamble. The
# subject line is the first non-comment, non-empty line.
subject=$(awk '
    /^#/      { next }       # comment lines
    /^$/      { next }       # blank lines
              { print; exit } # first real line = subject
' "$MSG_FILE")

# Lowercase + extract the conventional-commits keyword, tolerating
# whitespace before or after the colon.
keyword=$(printf '%s' "$subject" | tr '[:upper:]' '[:lower:]' \
    | sed -nE 's/^(break|feat|fix)[[:space:]]*:[[:space:]]?(.*)$/\1/p')

# Allow opting out per-commit (e.g. for chore: / docs: / ci: / refactor:)
if [[ "${SKIP_VERSION_BUMP:-0}" == "1" ]]; then
    exit 0
fi

# Map the keyword to a bump level. Anything else (chore:, docs:, refactor:,
# ci:, test:, style:, perf:, build:) is a no-op for versioning.
case "$keyword" in
    break) bump="major" ;;
    feat)  bump="minor" ;;
    fix)   bump="patch" ;;
    *)     exit 0 ;;
esac

# Bump VERSION and __init__.py in lockstep, using the same arithmetic
# the rest of the project uses (see version_bump.sh::next_version).
VERSION_FILE="$REPO_ROOT/VERSION"
INIT_FILE="$REPO_ROOT/app/__init__.py"
if [[ ! -f "$VERSION_FILE" ]]; then
    echo "commit-msg: $VERSION_FILE not found at repo root" >&2
    exit 1
fi

current=$(tr -d '[:space:]' < "$VERSION_FILE")
if ! [[ "$current" =~ ^([0-9]+)\.([0-9]+)\.([0-9]+)$ ]]; then
    echo "commit-msg: VERSION file is not semver (got: '$current')" >&2
    exit 1
fi
major="${BASH_REMATCH[1]}"
minor="${BASH_REMATCH[2]}"
patch="${BASH_REMATCH[3]}"

case "$bump" in
    major) next="$((major + 1)).0.0" ;;
    minor) next="${major}.$((minor + 1)).0" ;;
    patch) next="${major}.${minor}.$((patch + 1))" ;;
esac

if [[ "$current" == "$next" ]]; then
    # Already at the next version for this level — no work, no amend needed.
    exit 0
fi

# Write the new version to both places.
printf '%s\n' "$next" > "$VERSION_FILE"
if [[ -f "$INIT_FILE" ]]; then
    if grep -q '^__version__' "$INIT_FILE"; then
        sed -i.bak -E "s|^__version__ *= *\"[^\"]*\"|__version__ = \"$next\"|" "$INIT_FILE"
        rm -f "${INIT_FILE}.bak"
    else
        printf '\n__version__ = "%s"\n' "$next" >> "$INIT_FILE"
    fi
fi

# Stage the bumps so they ride along with the in-flight commit. Git's
# commit-msg hook runs BEFORE the commit object is constructed, so any
# files staged here are picked up by `git commit-tree` and end up in
# the commit's tree. No --amend needed.
git add -- "$VERSION_FILE" "$INIT_FILE"

printf '[version-bump] %s -> %s (%s)\n' "$current" "$next" "$bump" >&2
exit 0